<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="620" prefWidth="920" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projetbibliotheque.AdherentController">
    <top>
        <VBox spacing="4" style="-fx-background-color: linear-gradient(to right, #e6f0f7, #f6fbff); -fx-padding: 18;">
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2b2b2b;" text="Gestion des Adhérents" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #4b5563;" text="Ajout, Modification, Suppression, Consultation et Impression" />
        </VBox>
    </top>
    <center>
        <VBox spacing="12" style="-fx-padding: 16;">
            <VBox spacing="16" style="-fx-border-color: #9fb7cc; -fx-border-width: 1; -fx-background-color: #f8fbfe; -fx-padding: 16; -fx-background-radius: 4; -fx-border-radius: 4;">
                <GridPane hgap="24" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints minWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>
                    <children>
                        <Label text="Matricule" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtMatricule" promptText="Matricule" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Email" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <TextField fx:id="txtEmail" promptText="Email" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                        <Label text="Nom" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="txtNom" promptText="Nom" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Téléphone" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <TextField fx:id="txtTelephone" promptText="Téléphone" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                        <Label text="Prénom" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="txtPrenom" promptText="Prénom" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="Adresse" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                        <TextField fx:id="txtAdresse" promptText="Adresse" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                        <Label text="Actif" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <CheckBox fx:id="chkActif" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </children>
                </GridPane>
                <HBox alignment="CENTER" spacing="12">
                    <Button onAction="#ajouterAdherent" text="Ajouter" />
                    <Button onAction="#supprimerAdherent" text="Supprimer" />
                    <Button onAction="#modifierAdherent" text="Modifier" />
                    <Button onAction="#annuler" text="Annuler" />
                </HBox>
            </VBox>
            <TableView fx:id="tableAdherents" prefHeight="360">
                <columns>
                    <TableColumn fx:id="colNom" text="Nom" />
                    <TableColumn fx:id="colPrenom" text="Prénom" />
                    <TableColumn fx:id="colEmail" text="Email" />
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 12 16;">
            <Label text="Trier la liste par" />
            <ComboBox fx:id="comboTri">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Matricule" />
                        <String fx:value="Nom" />
                        <String fx:value="Prénom" />
                        <String fx:value="Email" />
                    </FXCollections>
                </items>
            </ComboBox>
            <Pane HBox.hgrow="ALWAYS" />
            <Label text="Rechercher" />
            <TextField prefWidth="220" />
            <Button onAction="#rechercherAdherent" text="Rechercher" />
        </HBox>
    </bottom>
</BorderPane>
