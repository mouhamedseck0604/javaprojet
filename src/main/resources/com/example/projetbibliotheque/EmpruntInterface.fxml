<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projetbibliotheque.EmpruntInterfaceController" prefWidth="920" prefHeight="620">

    <!-- Barre supérieure -->
    <top>
        <VBox spacing="4" style="-fx-background-color: linear-gradient(to right, #e6f0f7, #f6fbff); -fx-padding: 18;">
            <Label text="Gestion des Emprunts" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2b2b2b;"/>
            <Label text="Ajout, Modification, Suppression, Retour et Consultation" style="-fx-font-size: 12px; -fx-text-fill: #4b5563;"/>
        </VBox>
    </top>

    <!-- Centre : TableView -->
    <center>
        <VBox spacing="16" style="-fx-border-color: #9fb7cc; -fx-border-width: 1; -fx-background-color: #f8fbfe; -fx-padding: 16; -fx-background-radius: 4; -fx-border-radius: 4;">
        <TableView fx:id="empruntTable" prefHeight="400.0" prefWidth="1085.0" style="-fx-border-color: #9fb7cc; -fx-border-width: 1; -fx-background-color: #f8fbfe; -fx-background-radius: 4; -fx-border-radius: 4;">
            <columns>
                <TableColumn fx:id="livreColumn" prefWidth="150.0" text="Livre" />
                <TableColumn fx:id="adherentColumn" prefWidth="150.0" text="Adhérent" />
                <TableColumn fx:id="utilisateurColumn" prefWidth="150.0" text="Utilisateur" />
                <TableColumn fx:id="dateEmpruntColumn" prefWidth="120.0" text="Date Emprunt" />
                <TableColumn fx:id="dateRetourColumn" prefWidth="224.0" text="Date Retour" />
                <TableColumn fx:id="statutColumn" prefWidth="153.6" text="Statut" />
            </columns>
        </TableView>
        </VBox>
    </center>

    <!-- Bas : Formulaire + Boutons -->
    <bottom>
        <VBox spacing="16" style="-fx-padding: 16; -fx-background-color: #f8fbfe; -fx-border-color: #9fb7cc; -fx-border-width: 1; -fx-background-radius: 4; -fx-border-radius: 4;">
            <GridPane hgap="20" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                </rowConstraints>
                <children>
                    <Label text="Livre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="livreCombo" promptText="Sélectionner un livre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Adhérent:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="adherentCombo" promptText="Sélectionner un adhérent" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Utilisateur:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="utilisateurCombo" promptText="Sélectionner un utilisateur" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Date Emprunt:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dateEmpruntPicker" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Date Retour:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dateRetourPicker" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                </children>
            </GridPane>

            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="btnAjouter" onAction="#ajouterEmprunt" text="Ajouter" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <Button fx:id="btnModifier" onAction="#modifierEmprunt" text="Modifier" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <Button fx:id="btnSupprimer" onAction="#supprimerEmprunt" text="Supprimer" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <Button fx:id="btnAnnuler" onAction="#annulerFormulaire" text="Annuler" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <Button fx:id="btnRetour" onAction="#enregistrerRetour" text="Retour" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-background-radius: 6;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
