<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projetbibliotheque.AdminInterfaceController">
<top>
    <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Tableau de bord - Administrateur" />
</top>
<center>
    <VBox alignment="CENTER" prefHeight="210.0" prefWidth="160.0" spacing="10" stylesheets="@../../../CSS/tableaudebord.css">
         <Label fx:id="welcomeLabel" prefHeight="39.0" prefWidth="188.0" />
        <Button onAction="#handleUsers" prefHeight="50.0" prefWidth="350.0" text="Gestion des Utilisateurs" />
        <Button onAction="#verslivre" prefHeight="50.0" prefWidth="330.0" text="Gestion des Livres" />
        <Button onAction="#handleMembers" prefHeight="50.0" prefWidth="310.0" text="Gestion des Adhérents" />
        <Button onAction="#versemprunt" prefHeight="50.0" prefWidth="290.0" text="Gestion des Emprunts" />
        <Button onAction="#handleStats" prefHeight="50.0" prefWidth="270.0" text="Statistiques" />
         <Button fx:id="logoutButton" mnemonicParsing="false" prefHeight="34.0" prefWidth="191.0" text="Deconnection" />
    </VBox>
</center>
</BorderPane>
