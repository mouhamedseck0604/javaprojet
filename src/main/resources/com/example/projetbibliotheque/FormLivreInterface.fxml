<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.projetbibliotheque.LivreInterfaceController" prefWidth="920" prefHeight="620">

    <!-- Barre supérieure -->
    <top>
        <VBox spacing="4" style="-fx-background-color: linear-gradient(to right, #e6f0f7, #f6fbff); -fx-padding: 18;">
            <Label text="Gestion des Livres" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2b2b2b;"/>
            <Label text="Ajout, Modification, Suppression, Consultation et Recherche" style="-fx-font-size: 12px; -fx-text-fill: #4b5563;"/>
        </VBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <HBox alignment="TOP_LEFT" spacing="20" style="-fx-padding: 20;">

            <!-- Formulaire à gauche -->
            <VBox prefHeight="446.0" prefWidth="447.0" spacing="12" style="-fx-border-color: #9fb7cc; -fx-border-width: 1; -fx-background-color: #f8fbfe; -fx-padding: 16; -fx-background-radius: 4; -fx-border-radius: 4;">
                <TextField fx:id="txtisbn" promptText="ISBN" prefWidth="300"/>
                <TextField fx:id="txttitre" promptText="Titre" prefWidth="300"/>
                <TextField fx:id="txtauteur" promptText="Auteur" prefWidth="300"/>
                <ComboBox fx:id="categorieCombo" prefWidth="300" promptText="Catégorie"/>
                <TextField fx:id="txtannpub" promptText="Année de publication" prefWidth="300"/>
                <TextField fx:id="txtnbrexamp" promptText="Nombre d'exemplaires" prefWidth="300"/>
                <CheckBox fx:id="disponibleCheck" text="Disponible"/>

                <HBox spacing="12" alignment="CENTER">
                    <Button fx:id="btnsave" onAction="#ajouterLivre" text="Enregistrer" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 6;" prefWidth="120"/>
                    <Button fx:id="btnupdate" onAction="#modifierLivre" text="Modifier" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-background-radius: 6;" prefWidth="120"/>
                    <Button fx:id="btndelete" onAction="#supprimerLivre" text="Supprimer" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6;" prefWidth="120"/>
                    <Button fx:id="btnannul" onAction="#annulerLivre" text="Annuler" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-background-radius: 6;" prefWidth="120"/>
                </HBox>
            </VBox>

            <!-- Recherche et liste à droite -->
            <VBox prefHeight="446.0" prefWidth="931.0" spacing="20">
                <HBox alignment="TOP_RIGHT" spacing="10">
                    <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="220"/>
                    <ComboBox fx:id="critereCombo" prefHeight="26.0" prefWidth="120.0"/>
                    <Button fx:id="btnreach" onAction="#rechercherLivre" text="Rechercher" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 6;"/>
                </HBox>

                <TableView fx:id="livreTable" prefHeight="400.0" prefWidth="658.0" style="-fx-border-color: #9fb7cc; -fx-border-width: 1; -fx-background-color: #f8fbfe; -fx-background-radius: 4; -fx-border-radius: 4;">
                    <columns>
                        <TableColumn fx:id="isbnColumn" prefWidth="150" text="ISBN"/>
                        <TableColumn fx:id="titreColumn" prefWidth="275" text="Titre"/>
                        <TableColumn fx:id="auteurColumn" prefWidth="151" text="Auteur"/>
                        <TableColumn fx:id="categorieColumn" prefWidth="162" text="Catégorie"/>
                        <TableColumn fx:id="disponibleColumn" prefWidth="194" text="Disponible"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>
</BorderPane>
